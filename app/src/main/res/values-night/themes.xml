<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Solve_Bridge" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>

        <!-- Material 3 Color Overrides to remove default Violet/Purple in Dark Mode -->
        <item name="colorPrimaryContainer">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="colorSecondaryContainer">@color/colorPrimaryVariant</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <item name="colorTertiary">@color/colorSecondary</item>
        <item name="colorOnTertiary">@color/white</item>

        <item name="colorSurface">@color/black</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnSurfaceVariant">@color/white</item>

        <!-- Highlights -->
        <item name="colorAccent">@color/colorPrimary</item>
        <item name="colorControlHighlight">@color/colorPrimaryVariant</item>

        <item name="android:statusBarColor">@color/black</item>
        <item name="navigationViewStyle">@style/Widget.SolveBridge.NavigationView</item>
    </style>

    <style name="Theme.Solve_Bridge" parent="Base.Theme.Solve_Bridge" />

    <!-- Theme for Splash Screen to avoid double splash -->
    <style name="Theme.SolveBridge.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Widget.SolveBridge.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="itemShapeFillColor">@color/colorPrimaryVariant</item>
        <item name="itemIconTint">@color/white</item>
        <item name="itemTextColor">@color/white</item>
        <item name="itemRippleColor">@color/colorPrimary</item>
    </style>
</resources>
